# Copy this file to .env and fill in real values:
#   cp .env.example .env

# Server
PORT=8000
NODE_ENV=development

# Supabase — Project Settings → API
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase — Settings → API Keys → Secret keys
# Used by the backend crawler only. Never put this key in src/ or a VITE_ variable.
SUPABASE_SECRET_KEY=sb_secret_your-secret-key-here

# Supabase — Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.your-project-id:your-password@aws-0-region.pooler.supabase.com:6543/postgres

# JWT secret for your API (generate with: openssl rand -hex 32)
JWT_SECRET=change-this-to-a-long-random-string

# Frontend URL (for CORS)
CORS_ORIGIN=http://localhost:5173

# Microsoft Outlook / Graph
MICROSOFT_CLIENT_ID=your-microsoft-client-id-here
MICROSOFT_TENANT_ID=your-microsoft-tenant-id-here
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret-here
# Use organizations for a multi-tenant app that accepts NUS Microsoft accounts.
MICROSOFT_AUTHORITY_TENANT=organizations
# Add this exact Web redirect URI in the Microsoft app registration. It is
# used only by the one-time mailbox setup command, not by the Vite frontend.
MICROSOFT_SETUP_REDIRECT_URI=http://127.0.0.1:8787/callback
# Reserved for a future hosted, per-user Outlook connection flow.
MICROSOFT_REDIRECT_URI=https://your-site.netlify.app/.netlify/functions/outlook-callback

# Optional local crawler testing only.
# In production, refresh tokens should be stored per user in the database,
# encrypted, after the user finishes the Outlook OAuth flow.
OUTLOOK_REFRESH_TOKEN=your-refresh-token-for-local-testing
# Supabase auth.users UUID that owns the refresh token above. Required before a
# restricted Outlook opportunity can be published privately.
OUTLOOK_OWNER_USER_ID=your-supabase-user-uuid

# Optional broad public-web discovery. When configured, crawl:web and crawl:all
# use search results in addition to the fixed source list.
TAVILY_API_KEY=tvly-your-api-key-here

# Legacy Supabase projects may use this instead of SUPABASE_SECRET_KEY.
# SUPABASE_SERVICE_ROLE_KEY=your-legacy-service-role-key-here

# Estha AI
ESTHA_API_KEY=your-estha-api-key-here
ESTHA_API_URL=https://api.estha.ai/v1
